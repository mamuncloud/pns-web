#!/bin/sh

echo "✨ PNS-WEB Pre-commit Hook"
echo "--------------------------"

# Ensure dependencies are up to date
rm -rf node_modules && bun install || exit 1

echo "🧹 Running code cleanup (removing unused code/files)..."
bun run cleanup || exit 1

echo "🔍 Running type checking..."
bun run type-check || exit 1

echo "🔍 Running lint-staged check..."
bun x lint-staged || exit 1

echo "✅ Pre-commit checks passed!"
echo ""
